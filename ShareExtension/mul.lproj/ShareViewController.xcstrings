    "d3J-ot-h5d.title": {
      "comment": "Class = \"NSTextFieldCell\"; title = \"Scan this QR code with an Android device. The transfer will begin automatically.\"; ObjectID = \"d3J-ot-h5d\";",
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امسح رمز QR هذا باستخدام جهاز Android. ستبدأ عملية النقل تلقائياً."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Сканирайте този QR код с Android устройство. Трансферът ще започне автоматично."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Android ডিভাইস দিয়ে এই QR কোড স্ক্যান করুন। ট্রান্সফার স্বয়ংক্রিয়ভাবে শুরু হবে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Escaneja aquest codi QR amb un dispositiu Android. La transferència començarà automàticament."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Naskenujte tento QR kód zařízením Android. Přenos začne automaticky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan denne QR-kode med en Android-enhed. Overførslen starter automatisk."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanne diesen QR-Code mit einem Android-Gerät. Die Übertragung beginnt automatisch."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Σαρώστε αυτόν τον κωδικό QR με συσκευή Android. Η μεταφορά θα ξεκινήσει αυτόματα."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Scan this QR code with an Android device. The transfer will begin automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
