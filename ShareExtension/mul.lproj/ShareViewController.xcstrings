          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "I-scan ang QR code na ito gamit ang Android device. Awtomatikong magsisimula ang transfer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannez ce QR code avec un appareil Android. Le transfert démarrera automatiquement."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "סרוק קוד QR זה עם מכשיר Android. ההעברה תתחיל אוטומטית."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस QR कोड को Android डिवाइस से स्कैन करें। ट्रांसफर अपने आप शुरू होगा।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Skenirajte ovaj QR kod Android uređajem. Prijenos će početi automatski."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Olvasd be ezt a QR-kódot egy Android-eszközzel. Az átvitel automatikusan elindul."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindai kode QR ini dengan perangkat Android. Transfer akan dimulai otomatis."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansiona questo codice QR con un dispositivo Android. Il trasferimento inizierà automaticamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この QR コードを Android 端末で読み取ってください。転送が自動的に始まります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Android 기기로 이 QR 코드를 스캔하세요. 전송이 자동으로 시작됩니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nuskaitykite šį QR kodą Android įrenginiu. Perkėlimas prasidės automatiškai."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skenējiet šo QR kodu ar Android ierīci. Pārsūtīšana sāksies automātiski."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Imbas kod QR ini dengan peranti Android. Pemindahan akan bermula secara automatik."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skann denne QR-koden med en Android-enhet. Overføringen starter automatisk."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan deze QR-code met een Android-apparaat. De overdracht begint automatisch."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeskanuj ten kod QR urządzeniem Android. Transfer rozpocznie się automatycznie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escaneie este código QR com um dispositivo Android. A transferência começará automaticamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê este código QR com um dispositivo Android. A transferência começa automaticamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanează acest cod QR cu un dispozitiv Android. Transferul va începe automat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отсканируйте этот QR-код на Android-устройстве. Передача начнётся автоматически."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Naskenujte tento QR kód zariadením Android. Prenos sa začne automaticky."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skenirajte to kodo QR z napravo Android. Prenos se bo začel samodejno."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Скенирајте овај QR код Android уређајем. Пренос ће почети аутоматски."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skanna den här QR-koden med en Android-enhet. Överföringen startar automatiskt."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สแกน QR โค้ดนี้ด้วยอุปกรณ์ Android การถ่ายโอนจะเริ่มโดยอัตโนมัติ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
