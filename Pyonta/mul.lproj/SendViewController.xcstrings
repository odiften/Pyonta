    "d3J-ot-h5d.title": {
      "comment": "Class = \"NSTextFieldCell\"; title = \"Scan this QR code with an Android device. The transfer will begin automatically.\"; ObjectID = \"d3J-ot-h5d\";",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Scan this QR code with an Android device. The transfer will begin automatically."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отсканируйте этот QR-код на Android-устройстве. Передача начнётся автоматически."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امسح رمز QR هذا باستخدام جهاز Android. ستبدأ عملية النقل تلقائياً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanne diesen QR-Code mit einem Android-Gerät. Die Übertragung beginnt automatisch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanea este código QR con un dispositivo Android. La transferencia comenzará automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannez ce QR code avec un appareil Android. Le transfert démarrera automatiquement."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Olvasd be ezt a QR-kódot egy Android-eszközzel. Az átvitel automatikusan elindul."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansiona questo codice QR con un dispositivo Android. Il trasferimento inizierà automaticamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この QR コードを Android 端末で読み取ってください。転送が自動的に始まります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Android 기기로 이 QR 코드를 스캔하세요. 전송이 자동으로 시작됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan deze QR-code met een Android-apparaat. De overdracht begint automatisch."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escaneie este código QR com um dispositivo Android. A transferência começará automaticamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê este código QR com um dispositivo Android. A transferência começa automaticamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanează acest cod QR cu un dispozitiv Android. Transferul va începe automat."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สแกน QR โค้ดนี้ด้วยอุปกรณ์ Android การถ่ายโอนจะเริ่มโดยอัตโนมัติ"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відскануйте цей QR-код пристроєм Android. Передавання розпочнеться автоматично."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用 Android 设备扫描此二维码，传输将自动开始。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用 Android 裝置掃描此 QR 碼，傳輸將自動開始。"
          }
        }
      }
    },
