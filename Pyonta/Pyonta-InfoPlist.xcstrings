    "NSLocalNetworkUsageDescription": {
      "comment": "Shown in the macOS system prompt when the app first requests local network access. Must clearly state why the app needs to discover devices on the local Wi-Fi.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم Pyonta شبكتك المحلية للعثور على أجهزة Android القريبة ونقل الملفات عبر Quick Share."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta използва локалната мрежа, за да намира близки Android устройства и да прехвърля файлове чрез Quick Share."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কাছাকাছি Android ডিভাইস খুঁজতে এবং Quick Share দিয়ে ফাইল স্থানান্তর করতে Pyonta আপনার লোকাল নেটওয়ার্ক ব্যবহার করে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta utilitza la xarxa local per descobrir dispositius Android propers i transferir fitxers amb Quick Share."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta používá místní síť k vyhledání blízkých zařízení Android a přenosu souborů přes Quick Share."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta bruger dit lokale netværk til at finde Android-enheder i nærheden og overføre filer via Quick Share."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta verwendet Ihr lokales Netzwerk, um Android-Geräte in der Nähe zu finden und Dateien über Quick Share zu übertragen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Pyonta χρησιμοποιεί το τοπικό σας δίκτυο για να εντοπίζει κοντινές συσκευές Android και να μεταφέρει αρχεία μέσω Quick Share."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta uses your local network to discover nearby Android devices and transfer files via Quick Share."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta usa tu red local para descubrir dispositivos Android cercanos y transferir archivos mediante Quick Share."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta kasutab teie kohalikku võrku lähedal asuvate Android-seadmete leidmiseks ja failide edastamiseks Quick Share'i kaudu."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta käyttää paikallisverkkoasi löytääkseen lähellä olevia Android-laitteita ja siirtääkseen tiedostoja Quick Sharella."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ginagamit ng Pyonta ang iyong local network para mahanap ang malapit na Android devices at maglipat ng files gamit ang Quick Share."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta utilise votre réseau local pour détecter les appareils Android à proximité et transférer des fichiers via Quick Share."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta משתמש ברשת המקומית שלך כדי לגלות מכשירי Android קרובים ולהעביר קבצים באמצעות Quick Share."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta पास के Android डिवाइस खोजने और Quick Share से फ़ाइलें ट्रांसफर करने के लिए आपके स्थानीय नेटवर्क का उपयोग करता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta koristi vašu lokalnu mrežu za pronalaženje obližnjih Android uređaja i prijenos datoteka putem Quick Sharea."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pyonta a helyi hálózatot használja a közeli Android eszközök felderítéséhez és a fájlok Quick Share-en keresztüli átviteléhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta menggunakan jaringan lokal Anda untuk menemukan perangkat Android di sekitar dan mentransfer file lewat Quick Share."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta utilizza la rete locale per rilevare dispositivi Android nelle vicinanze e trasferire file tramite Quick Share."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くの Android デバイスを探し、Quick Share でファイルを送受信するために、Pyonta はローカルネットワークを使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta는 주변 Android 기기를 찾고 Quick Share를 통해 파일을 전송하기 위해 로컬 네트워크를 사용합니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta naudoja jūsų vietinį tinklą netoliese esantiems Android įrenginiams aptikti ir failams perkelti per Quick Share."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta izmanto jūsu lokālo tīklu, lai atrastu tuvumā esošas Android ierīces un pārsūtītu failus ar Quick Share."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta menggunakan rangkaian setempat anda untuk menemui peranti Android berdekatan dan memindahkan fail melalui Quick Share."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta bruker lokalnettverket ditt til å finne Android-enheter i nærheten og overføre filer via Quick Share."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta gebruikt uw lokale netwerk om Android-apparaten in de buurt te vinden en bestanden via Quick Share over te dragen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta używa sieci lokalnej do wykrywania pobliskich urządzeń Android i przesyłania plików przez Quick Share."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pyonta usa sua rede local para descobrir dispositivos Android próximos e transferir arquivos via Quick Share."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pyonta utiliza a sua rede local para descobrir dispositivos Android próximos e transferir ficheiros via Quick Share."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta folosește rețeaua locală pentru a descoperi dispozitive Android din apropiere și a transfera fișiere prin Quick Share."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta использует вашу локальную сеть для обнаружения находящихся рядом устройств Android и передачи файлов через Quick Share."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta používa vašu lokálnu sieť na vyhľadanie blízkych zariadení Android a prenos súborov cez Quick Share."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta uporablja vaše lokalno omrežje za odkrivanje bližnjih naprav Android in prenos datotek prek Quick Share."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta користи вашу локалну мрежу да пронађе оближње Android уређаје и пренесе датотеке преко Quick Share-а."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta använder ditt lokala nätverk för att hitta Android-enheter i närheten och överföra filer via Quick Share."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta ใช้เครือข่ายภายในของคุณเพื่อค้นหาอุปกรณ์ Android ที่อยู่ใกล้เคียงและถ่ายโอนไฟล์ผ่าน Quick Share"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta, yakındaki Android aygıtlarını bulmak ve Quick Share ile dosya aktarmak için yerel ağınızı kullanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta використовує вашу локальну мережу для пошуку поблизу пристроїв Android і передавання файлів через Quick Share."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta sử dụng mạng cục bộ của bạn để tìm thiết bị Android gần đó và chuyển tệp qua Quick Share."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta 使用您的本地网络查找附近的 Android 设备并通过 Quick Share 传输文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta 使用您的本機網路尋找附近的 Android 裝置，並透過 Quick Share 傳輸檔案。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
