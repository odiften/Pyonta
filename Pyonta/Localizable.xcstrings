    "PlusUnavailable.Message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم إعداد Pyonta+ بعد. أضف مفتاح RevenueCat العام قبل إصدار هذا البناء."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ още не е конфигуриран. Добавете публичния API ключ на RevenueCat, преди да пуснете този билд."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ এখনও কনফিগার করা হয়নি। এই বিল্ড প্রকাশের আগে RevenueCat public API key যোগ করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ encara no està configurat. Afegeix la clau API pública de RevenueCat abans de publicar aquesta build."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ ještě není nakonfigurován. Před vydáním této verze přidejte veřejný API klíč RevenueCat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ er ikke konfigureret endnu. Tilføj RevenueCats offentlige API-nøgle, før denne build udgives."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ ist noch nicht konfiguriert. Füge vor der Veröffentlichung dieses Builds den öffentlichen RevenueCat-API-Schlüssel hinzu."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Pyonta+ δεν έχει διαμορφωθεί ακόμη. Προσθέστε το δημόσιο API key του RevenueCat πριν κυκλοφορήσει αυτό το build."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ is not configured yet. Add the RevenueCat public API key before releasing this build."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ aún no está configurado. Añade la clave API pública de RevenueCat antes de publicar esta compilación."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ pole veel seadistatud. Lisage RevenueCati avalik API võti enne selle buildi väljalaskmist."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+:aa ei ole vielä määritetty. Lisää RevenueCatin julkinen API-avain ennen tämän buildin julkaisua."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Hindi pa naka-configure ang Pyonta+. Idagdag ang RevenueCat public API key bago i-release ang build na ito."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ n’est pas encore configuré. Ajoutez la clé API publique RevenueCat avant de publier cette build."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ עדיין לא הוגדר. הוסף את מפתח ה-API הציבורי של RevenueCat לפני שחרור build זה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ अभी कॉन्फ़िगर नहीं है। इस build को जारी करने से पहले RevenueCat public API key जोड़ें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ još nije konfiguriran. Dodajte javni API ključ RevenueCat prije izdavanja ovog builda."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pyonta+ még nincs beállítva. A build kiadása előtt add hozzá a RevenueCat nyilvános API-kulcsát."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ belum dikonfigurasi. Tambahkan public API key RevenueCat sebelum merilis build ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ non è ancora configurato. Aggiungi la chiave API pubblica di RevenueCat prima di rilasciare questa build."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ はまだ設定されていません。リリース前に RevenueCat の public API key を設定してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+가 아직 설정되지 않았습니다. 이 빌드를 출시하기 전에 RevenueCat 공개 API 키를 추가하세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ dar nesukonfigūruota. Prieš išleisdami šį build pridėkite RevenueCat viešą API raktą."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ vēl nav konfigurēts. Pirms šī build izlaišanas pievienojiet RevenueCat publisko API atslēgu."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ belum dikonfigurasikan. Tambahkan public API key RevenueCat sebelum mengeluarkan build ini."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ er ikke konfigurert ennå. Legg til RevenueCats offentlige API-nøkkel før denne builden utgis."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ is nog niet geconfigureerd. Voeg de openbare RevenueCat API-sleutel toe voordat je deze build uitbrengt."
