            "value": "Kopeeri esmalt tekst ja proovi uuesti."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopioi ensin tekstiä ja yritä uudelleen."
          }
        },
        "fil": {
          "stringUnit": {
