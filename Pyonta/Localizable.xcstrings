    "FirstLaunchNotice.Message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر على أيقونة Pyonta في شريط القوائم لإرسال الملفات أو الاستلام من Android أو الترقية إلى Pyonta+ أو إنهاء التطبيق."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Щракнете върху иконата Pyonta в лентата с менюта, за да изпращате файлове, получавате от Android, надграждате до Pyonta+ или излизате."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ফাইল পাঠানো, Android থেকে গ্রহণ, Pyonta+ আপগ্রেড বা বন্ধ করতে মেনু বারের Pyonta আইকনে ক্লিক করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Fes clic a la icona de Pyonta a la barra de menús per enviar fitxers, rebre d'Android, actualitzar a Pyonta+ o sortir."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknutím na ikonu Pyonta v řádku nabídek můžete posílat soubory, přijímat z Androidu, upgradovat na Pyonta+ nebo aplikaci ukončit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik på Pyonta-ikonet i menulinjen for at sende filer, modtage fra Android, opgradere til Pyonta+ eller afslutte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicke auf das Pyonta-Symbol in der Menüleiste, um Dateien zu senden, von Android zu empfangen, auf Pyonta+ upzugraden oder die App zu beenden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κάντε κλικ στο εικονίδιο Pyonta στη γραμμή μενού για αποστολή αρχείων, λήψη από Android, αναβάθμιση σε Pyonta+ ή έξοδο."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the Pyonta icon in the menu bar to send files, receive from Android, upgrade to Pyonta+, or quit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en el icono de Pyonta en la barra de menús para enviar archivos, recibir desde Android, actualizar a Pyonta+ o salir."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Klõpsa menüüribal Pyonta ikooni, et saata faile, võtta vastu Androidist, uuendada Pyonta+ versioonile või väljuda."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Klikkaa Pyonta-kuvaketta valikkorivillä lähettääksesi tiedostoja, vastaanottaaksesi Androidista, päivittääksesi Pyonta+:aan tai lopettaaksesi."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "I-click ang icon ng Pyonta sa menu bar para magpadala ng file, tumanggap mula Android, mag-upgrade sa Pyonta+, o mag-quit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur l’icône Pyonta dans la barre des menus pour envoyer des fichiers, recevoir depuis Android, passer à Pyonta+ ou quitter."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לחץ על סמל Pyonta בשורת התפריטים כדי לשלוח קבצים, לקבל מ-Android, לשדרג ל-Pyonta+ או לצאת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइलें भेजने, Android से प्राप्त करने, Pyonta+ में अपग्रेड करने या बंद करने के लिए मेनू बार में Pyonta आइकन क्लिक करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknite ikonu Pyonta u traci izbornika za slanje datoteka, primanje s Androida, nadogradnju na Pyonta+ ili izlaz."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kattints a Pyonta ikonra a menüsorban fájlok küldéséhez, Androidról való fogadáshoz, Pyonta+-ra frissítéshez vagy kilépéshez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik ikon Pyonta di bilah menu untuk mengirim file, menerima dari Android, upgrade ke Pyonta+, atau keluar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai clic sull’icona Pyonta nella barra dei menu per inviare file, ricevere da Android, passare a Pyonta+ o uscire."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイル送信、Android からの受信、Pyonta+ へのアップグレード、終了は、メニューバーの Pyonta アイコンから行えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일 보내기, Android에서 받기, Pyonta+ 업그레이드 또는 종료는 메뉴 막대의 Pyonta 아이콘에서 할 수 있습니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Spustelėkite Pyonta piktogramą meniu juostoje, kad siųstumėte failus, gautumėte iš Android, atnaujintumėte į Pyonta+ arba uždarytumėte."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Noklikšķiniet uz Pyonta ikonas izvēļņu joslā, lai sūtītu failus, saņemtu no Android, jauninātu uz Pyonta+ vai izietu."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik ikon Pyonta dalam bar menu untuk menghantar fail, menerima daripada Android, menaik taraf kepada Pyonta+ atau keluar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Klikk på Pyonta-ikonet i menylinjen for å sende filer, motta fra Android, oppgradere til Pyonta+ eller avslutte."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik op het Pyonta-symbool in de menubalk om bestanden te verzenden, vanaf Android te ontvangen, naar Pyonta+ te upgraden of te stoppen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknij ikonę Pyonta na pasku menu, aby wysyłać pliki, odbierać z Androida, uaktualnić do Pyonta+ lub zakończyć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique no ícone do Pyonta na barra de menus para enviar arquivos, receber do Android, fazer upgrade para Pyonta+ ou sair."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique no ícone do Pyonta na barra de menus para enviar ficheiros, receber do Android, atualizar para Pyonta+ ou sair."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Faceți clic pe pictograma Pyonta din bara de meniu pentru a trimite fișiere, a primi de pe Android, a face upgrade la Pyonta+ sau a ieși."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите значок Pyonta в строке меню, чтобы отправлять файлы, получать с Android, перейти на Pyonta+ или выйти."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknite na ikonu Pyonta v lište menu, ak chcete odosielať súbory, prijímať z Androidu, upgradovať na Pyonta+ alebo skončiť."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknite ikono Pyonta v menijski vrstici za pošiljanje datotek, prejemanje iz Androida, nadgradnjo na Pyonta+ ali izhod."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Кликните на Pyonta икону у траци менија да шаљете датотеке, примате са Android-а, надоградите на Pyonta+ или изађете."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicka på Pyonta-ikonen i menyraden för att skicka filer, ta emot från Android, uppgradera till Pyonta+ eller avsluta."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คลิกไอคอน Pyonta ในแถบเมนูเพื่อส่งไฟล์ รับจาก Android อัปเกรดเป็น Pyonta+ หรือออกจากแอป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dosya göndermek, Android'den almak, Pyonta+'a yükseltmek veya çıkmak için menü çubuğundaki Pyonta simgesine tıklayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Натисніть іконку Pyonta в рядку меню, щоб надсилати файли, отримувати з Android, оновити до Pyonta+ або вийти."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấp biểu tượng Pyonta trên thanh menu để gửi tệp, nhận từ Android, nâng cấp lên Pyonta+ hoặc thoát."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按菜单栏中的 Pyonta 图标即可发送文件、从 Android 接收、升级到 Pyonta+ 或退出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點按選單列中的 Pyonta 圖示即可傳送檔案、從 Android 接收、升級到 Pyonta+ 或結束。"
          }
        }
      }
    },
