    "PlusPurchaseFailed.Message": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"تعذر إكمال الشراء. يرجى المحاولة مرة أخرى."}},"de":{"stringUnit":{"state":"translated","value":"Der Kauf konnte nicht abgeschlossen werden. Bitte versuche es erneut."}},"en":{"stringUnit":{"state":"translated","value":"Purchase could not be completed. Please try again."}},"es":{"stringUnit":{"state":"translated","value":"No se pudo completar la compra. Inténtalo de nuevo."}},"fr":{"stringUnit":{"state":"translated","value":"L’achat n’a pas pu être finalisé. Veuillez réessayer."}},"hu":{"stringUnit":{"state":"translated","value":"A vásárlást nem sikerült befejezni. Próbáld újra."}},"it":{"stringUnit":{"state":"translated","value":"Impossibile completare l’acquisto. Riprova."}},"ja":{"stringUnit":{"state":"translated","value":"購入を完了できませんでした。もう一度お試しください。"}},"ko":{"stringUnit":{"state":"translated","value":"구입을 완료할 수 없습니다. 다시 시도해 주세요."}},"nl":{"stringUnit":{"state":"translated","value":"De aankoop kon niet worden voltooid. Probeer het opnieuw."}},"pt-BR":{"stringUnit":{"state":"translated","value":"A compra não pôde ser concluída. Tente novamente."}},"pt-PT":{"stringUnit":{"state":"translated","value":"A compra não pôde ser concluída. Tente novamente."}},"ro":{"stringUnit":{"state":"translated","value":"Achiziția nu a putut fi finalizată. Încercați din nou."}},"ru":{"stringUnit":{"state":"translated","value":"Не удалось завершить покупку. Повторите попытку."}},"th":{"stringUnit":{"state":"translated","value":"ไม่สามารถทำการซื้อให้เสร็จสมบูรณ์ได้ โปรดลองอีกครั้ง"}},"uk":{"stringUnit":{"state":"translated","value":"Не вдалося завершити покупку. Спробуйте ще раз."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"无法完成购买。请重试。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"無法完成購買。請再試一次。"}}}}
