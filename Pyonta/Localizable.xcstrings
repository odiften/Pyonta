    "AutoAcceptFiles.Tooltip": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، تُقبل الملفات والنصوص وعناوين URL من Android دون سؤال. إذا كان فتح عناوين URL مفعّلًا أيضًا، قد تُفتح عناوين URL فورًا."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Когато е включено, файлове, текст и URL адреси от Android се приемат без питане. Ако автоматичното отваряне на URL също е включено, получените URL адреси могат да се отворят веднага."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "চালু থাকলে Android থেকে ফাইল, টেক্সট ও URL জিজ্ঞাসা ছাড়াই গ্রহণ করা হয়। URL স্বয়ংক্রিয়ভাবে খোলা থাকলে, পাওয়া URL সঙ্গে সঙ্গে খুলতে পারে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Quan és activat, els fitxers, el text i els URL d'Android s'accepten sense preguntar. Si l'obertura d'URL també és activada, els URL rebuts es poden obrir immediatament."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Když je zapnuto, soubory, text a URL z Androidu se přijmou bez dotazu. Pokud je zapnuto i otevírání URL, přijaté URL se mohou otevřít okamžitě."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når dette er slået til, accepteres filer, tekst og URL'er fra Android uden at spørge. Hvis automatisk åbning af URL'er også er slået til, kan modtagne URL'er åbnes med det samme."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, werden Dateien, Text und URLs von Android ohne Nachfrage angenommen. Ist das Öffnen von URLs ebenfalls aktiviert, können empfangene URLs sofort geöffnet werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Όταν είναι ενεργό, αρχεία, κείμενο και URL από Android γίνονται δεκτά χωρίς ερώτηση. Αν είναι ενεργό και το άνοιγμα URL, τα ληφθέντα URL μπορούν να ανοίγουν αμέσως."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, files, text, and URLs from Android are accepted without asking. If URL opening is also on, received URLs can open immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, archivos, texto y URLs de Android se aceptan sin preguntar. Si abrir URLs también está activado, las URLs recibidas pueden abrirse de inmediato."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kui see on sees, võetakse Androidist tulevad failid, tekst ja URL-id vastu küsimata. Kui ka URL-ide avamine on sees, võivad vastuvõetud URL-id kohe avaneda."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun tämä on käytössä, Androidista tulevat tiedostot, teksti ja URL-osoitteet hyväksytään kysymättä. Jos URL-osoitteiden avaaminen on myös käytössä, vastaanotetut URL-osoitteet voivat avautua heti."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapag naka-on, tinatanggap ang mga file, text, at URL mula Android nang walang tanong. Kung naka-on din ang pagbubukas ng URL, maaaring agad mabuksan ang natanggap na URL."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si activé, les fichiers, textes et URL venant d’Android sont acceptés sans demande. Si l’ouverture des URL est aussi activée, les URL reçues peuvent s’ouvrir immédiatement."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כאשר מופעל, קבצים, טקסט וכתובות URL מ-Android מתקבלים בלי לשאול. אם גם פתיחת URL מופעלת, כתובות URL שהתקבלו יכולות להיפתח מיד."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर Android से फ़ाइलें, टेक्स्ट और URL बिना पूछे स्वीकार किए जाते हैं। अगर URL खोलना भी चालू है, तो प्राप्त URL तुरंत खुल सकते हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kada je uključeno, datoteke, tekst i URL-ovi s Androida prihvaćaju se bez pitanja. Ako je uključeno i otvaranje URL-ova, primljeni URL-ovi mogu se odmah otvoriti."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekapcsolva az Androidról érkező fájlok, szövegek és URL-ek kérdés nélkül elfogadásra kerülnek. Ha az URL-ek megnyitása is be van kapcsolva, a fogadott URL-ek azonnal megnyílhatnak."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika aktif, file, teks, dan URL dari Android diterima tanpa bertanya. Jika pembukaan URL juga aktif, URL yang diterima dapat langsung terbuka."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se attivo, file, testo e URL da Android vengono accettati senza chiedere. Se è attiva anche l’apertura degli URL, gli URL ricevuti possono aprirsi subito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンのとき、Android からのファイル・テキスト・URLを確認なしで受信します。「URLを自動で開く」もオンの場合、URLはすぐブラウザで開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜져 있으면 Android에서 온 파일, 텍스트, URL을 확인 없이 받습니다. URL 열기도 켜져 있으면 받은 URL이 즉시 열릴 수 있습니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Kai įjungta, failai, tekstas ir URL iš Android priimami neklausiant. Jei URL atidarymas taip pat įjungtas, gauti URL gali būti atidaryti iš karto."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kad ieslēgts, faili, teksts un URL no Android tiek pieņemti bez jautāšanas. Ja ieslēgta arī URL atvēršana, saņemtie URL var tikt atvērti uzreiz."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Apabila dihidupkan, fail, teks dan URL daripada Android diterima tanpa bertanya. Jika pembukaan URL juga dihidupkan, URL yang diterima boleh dibuka serta-merta."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Når dette er på, godtas filer, tekst og URL-er fra Android uten å spørre. Hvis URL-åpning også er på, kan mottatte URL-er åpnes umiddelbart."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer ingeschakeld, worden bestanden, tekst en URL's vanaf Android zonder vragen geaccepteerd. Als URL's openen ook aan staat, kunnen ontvangen URL's direct openen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdy włączone, pliki, tekst i adresy URL z Androida są akceptowane bez pytania. Jeśli otwieranie URL też jest włączone, odebrane adresy URL mogą otwierać się od razu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, arquivos, textos e URLs do Android são aceitos sem perguntar. Se abrir URLs também estiver ativado, URLs recebidas podem abrir imediatamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, ficheiros, texto e URLs do Android são aceites sem perguntar. Se a abertura de URLs também estiver ativada, os URLs recebidos podem abrir imediatamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Când este activat, fișierele, textul și URL-urile de pe Android sunt acceptate fără întrebare. Dacă deschiderea URL-urilor este și ea activată, URL-urile primite se pot deschide imediat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда включено, файлы, текст и URL с Android принимаются без запроса. Если открытие URL тоже включено, полученные URL могут открываться сразу."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Keď je zapnuté, súbory, text a URL z Androidu sa prijímajú bez opýtania. Ak je zapnuté aj otváranie URL, prijaté URL sa môžu otvoriť okamžite."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko je vklopljeno, se datoteke, besedilo in URL-ji iz Androida sprejmejo brez vprašanja. Če je vklopljeno tudi odpiranje URL-jev, se lahko prejeti URL-ji odprejo takoj."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Када је укључено, датотеке, текст и URL-ови са Android-а прихватају се без питања. Ако је укључено и отварање URL-ова, примљени URL-ови могу одмах да се отворе."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "När detta är på tas filer, text och URL:er från Android emot utan att fråga. Om URL-öppning också är på kan mottagna URL:er öppnas direkt."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เมื่อเปิด ไฟล์ ข้อความ และ URL จาก Android จะถูกรับโดยไม่ถาม หากเปิดการเปิด URL ด้วย URL ที่ได้รับอาจเปิดทันที"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açıkken Android'den gelen dosyalar, metin ve URL'ler sorulmadan kabul edilir. URL açma da açıksa alınan URL'ler hemen açılabilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коли ввімкнено, файли, текст і URL з Android приймаються без запиту. Якщо відкривання URL також увімкнено, отримані URL можуть відкриватися одразу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khi bật, tệp, văn bản và URL từ Android được chấp nhận mà không hỏi. Nếu mở URL cũng bật, URL đã nhận có thể mở ngay."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启时，来自 Android 的文件、文本和 URL 会无需确认接收。如果也开启了打开 URL，收到的 URL 可能会立即打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟時，來自 Android 的檔案、文字和 URL 會無需確認接收。如果也開啟了開啟 URL，收到的 URL 可能會立即開啟。"
          }
        }
      }
    },
