    "PlusRequired.Message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب الاستلام من Android اشتراك Pyonta+. قم بالترقية، ثم اطلب من المرسل المحاولة مرة أخرى."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Получаването от Android изисква Pyonta+. Надградете и помолете подателя да опита отново."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Android থেকে গ্রহণ করতে Pyonta+ দরকার। আপগ্রেড করে প্রেরককে আবার চেষ্টা করতে বলুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Rebre d'Android requereix Pyonta+. Actualitza i demana al remitent que ho torni a provar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Příjem z Androidu vyžaduje Pyonta+. Upgradujte a požádejte odesílatele, aby to zkusil znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Modtagelse fra Android kræver Pyonta+. Opgrader, og bed afsenderen prøve igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für den Empfang von Android ist Pyonta+ erforderlich. Führe ein Upgrade durch und bitte den Absender, es erneut zu versuchen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η λήψη από Android απαιτεί Pyonta+. Αναβαθμίστε και ζητήστε από τον αποστολέα να δοκιμάσει ξανά."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Receiving from Android requires Pyonta+. Upgrade, then ask the sender to try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibir desde Android requiere Pyonta+. Actualiza y pide al remitente que lo intente de nuevo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Androidist vastuvõtmiseks on vaja Pyonta+. Uuendage ja paluge saatjal uuesti proovida."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Androidista vastaanottaminen vaatii Pyonta+:n. Päivitä ja pyydä lähettäjää yrittämään uudelleen."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Kailangan ang Pyonta+ para tumanggap mula Android. Mag-upgrade, pagkatapos ay hilingin sa nagpadala na subukang muli."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La réception depuis Android nécessite Pyonta+. Passez à la version supérieure, puis demandez à l’expéditeur de réessayer."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קבלה מ-Android דורשת Pyonta+. שדרג ואז בקש מהשולח לנסות שוב."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Android से प्राप्त करने के लिए Pyonta+ चाहिए। अपग्रेड करें, फिर भेजने वाले से दोबारा कोशिश करने को कहें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Primanje s Androida zahtijeva Pyonta+. Nadogradite i zamolite pošiljatelja da pokuša ponovno."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az Androidról való fogadáshoz Pyonta+ szükséges. Frissíts, majd kérd meg a küldőt, hogy próbálja újra."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menerima dari Android memerlukan Pyonta+. Upgrade, lalu minta pengirim mencoba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La ricezione da Android richiede Pyonta+. Esegui l’upgrade, poi chiedi al mittente di riprovare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Android から受信するには Pyonta+ が必要です。アップグレード後、もう一度送信してもらってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Android에서 받으려면 Pyonta+가 필요합니다. 업그레이드한 뒤 보낸 사람에게 다시 시도해 달라고 하세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gavimui iš Android reikia Pyonta+. Atnaujinkite ir paprašykite siuntėjo bandyti dar kartą."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Saņemšanai no Android nepieciešams Pyonta+. Jauniniet un palūdziet sūtītājam mēģināt vēlreiz."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menerima daripada Android memerlukan Pyonta+. Naik taraf, kemudian minta penghantar cuba lagi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mottak fra Android krever Pyonta+. Oppgrader, og be avsenderen prøve igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontvangen vanaf Android vereist Pyonta+. Upgrade en vraag de afzender het opnieuw te proberen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odbieranie z Androida wymaga Pyonta+. Uaktualnij i poproś nadawcę, aby spróbował ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Receber do Android requer Pyonta+. Faça upgrade e peça ao remetente para tentar novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Receber do Android requer Pyonta+. Atualize e peça ao remetente para tentar novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Primirea de pe Android necesită Pyonta+. Faceți upgrade, apoi cereți expeditorului să încerce din nou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для получения с Android требуется Pyonta+. Перейдите на Pyonta+, затем попросите отправителя повторить попытку."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Príjem z Androidu vyžaduje Pyonta+. Upgradujte a požiadajte odosielateľa, aby to skúsil znova."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prejemanje iz Androida zahteva Pyonta+. Nadgradite in prosite pošiljatelja, naj poskusi znova."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Примање са Android-а захтева Pyonta+. Надоградите и замолите пошиљаоца да покуша поново."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mottagning från Android kräver Pyonta+. Uppgradera och be avsändaren försöka igen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การรับจาก Android ต้องใช้ Pyonta+ โปรดอัปเกรด แล้วขอให้ผู้ส่งลองอีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Android'den almak için Pyonta+ gerekir. Yükseltin, sonra gönderenden tekrar denemesini isteyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Для отримання з Android потрібен Pyonta+. Оновіть, а потім попросіть відправника спробувати ще раз."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhận từ Android cần Pyonta+. Hãy nâng cấp, rồi nhờ người gửi thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 Android 接收需要 Pyonta+。升级后,请让发送者再试一次。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從 Android 接收需要 Pyonta+。升級後,請讓傳送者再試一次。"
          }
        }
      }
    },
