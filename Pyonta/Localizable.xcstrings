    "LaunchAtLogin.Tooltip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, Pyonta starts automatically when you log in to your Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、Mac にログインしたときに Pyonta が自動で起動します。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يبدأ Pyonta تلقائيًا عند تسجيل الدخول إلى Mac."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, startet Pyonta automatisch, wenn du dich an deinem Mac anmeldest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, Pyonta se inicia automáticamente al iniciar sesión en tu Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, Pyonta démarre automatiquement à l’ouverture de session sur votre Mac."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekapcsolva a Pyonta automatikusan elindul, amikor bejelentkezel a Mac-edre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se attivato, Pyonta si avvia automaticamente quando accedi al tuo Mac."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜져 있으면 Mac에 로그인할 때 Pyonta가 자동으로 실행됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Indien ingeschakeld, start Pyonta automatisch wanneer je inlogt op je Mac."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o Pyonta inicia automaticamente ao você fazer login no Mac."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o Pyonta inicia automaticamente ao iniciar sessão no Mac."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Când este activat, Pyonta pornește automat la autentificarea în Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если включено, Pyonta запускается автоматически при входе в систему Mac."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เมื่อเปิด Pyonta จะเริ่มทำงานโดยอัตโนมัติเมื่อคุณเข้าสู่ระบบ Mac"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коли увімкнено, Pyonta запускається автоматично під час входу в Mac."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后,Pyonta 将在你登录 Mac 时自动启动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後,Pyonta 會在你登入 Mac 時自動啟動。"
          }
        }
      }
    },
    "OpenReceivedURLs": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"فتح عناوين URL تلقائيًا"}},"de":{"stringUnit":{"state":"translated","value":"URLs automatisch öffnen"}},"en":{"stringUnit":{"state":"translated","value":"Open URLs automatically"}},"es":{"stringUnit":{"state":"translated","value":"Abrir URLs automáticamente"}},"fr":{"stringUnit":{"state":"translated","value":"Ouvrir les URL automatiquement"}},"hu":{"stringUnit":{"state":"translated","value":"URL-ek automatikus megnyitása"}},"it":{"stringUnit":{"state":"translated","value":"Apri URL automaticamente"}},"ja":{"stringUnit":{"state":"translated","value":"URLを自動で開く"}},"ko":{"stringUnit":{"state":"translated","value":"URL 자동으로 열기"}},"nl":{"stringUnit":{"state":"translated","value":"URL's automatisch openen"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Abrir URLs automaticamente"}},"pt-PT":{"stringUnit":{"state":"translated","value":"Abrir URLs automaticamente"}},"ro":{"stringUnit":{"state":"translated","value":"Deschide automat URL-urile"}},"ru":{"stringUnit":{"state":"translated","value":"Автоматически открывать URL"}},"th":{"stringUnit":{"state":"translated","value":"เปิด URL อัตโนมัติ"}},"uk":{"stringUnit":{"state":"translated","value":"Автоматично відкривати URL"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"自动打开 URL"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"自動開啟 URL"}}}},
    "OpenReceivedURLs.Tooltip": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"متاح عند تفعيل الاستلام دون سؤال. عند تشغيله، تُفتح عناوين URL من Android فورًا في متصفحك الافتراضي؛ وعند إيقافه، تُنسخ إلى الحافظة."}},"de":{"stringUnit":{"state":"translated","value":"Verfügbar, wenn Ohne Nachfrage empfangen aktiv ist. Ist dies eingeschaltet, öffnen sich URLs von Android sofort im Standardbrowser; andernfalls werden sie in die Zwischenablage kopiert."}},"en":{"stringUnit":{"state":"translated","value":"Available when Receive without asking is on. When on, URLs from Android open in your default browser immediately; when off, URLs are copied to clipboard."}},"es":{"stringUnit":{"state":"translated","value":"Disponible cuando Recibir sin preguntar está activado. Si está activado, las URLs de Android se abren de inmediato en tu navegador predeterminado; si está desactivado, se copian al portapapeles."}},"fr":{"stringUnit":{"state":"translated","value":"Disponible lorsque Recevoir sans demander est activé. Si activé, les URL d’Android s’ouvrent immédiatement dans le navigateur par défaut; sinon, elles sont copiées dans le presse-papiers."}},"hu":{"stringUnit":{"state":"translated","value":"Akkor érhető el, ha a Fogadás kérdés nélkül be van kapcsolva. Bekapcsolva az Androidról érkező URL-ek azonnal megnyílnak az alapértelmezett böngészőben; kikapcsolva a vágólapra másolódnak."}},"it":{"stringUnit":{"state":"translated","value":"Disponibile quando Ricevi senza chiedere è attivo. Se attivo, gli URL da Android si aprono subito nel browser predefinito; se disattivo, vengono copiati negli appunti."}},"ja":{"stringUnit":{"state":"translated","value":"「確認なしで受信」がオンのときに使えます。オンの場合、Android からのURLをすぐ既定のブラウザで開きます。オフの場合はクリップボードへコピーします。"}},"ko":{"stringUnit":{"state":"translated","value":"확인 없이 받기가 켜져 있을 때 사용할 수 있습니다. 켜면 Android에서 온 URL을 즉시 기본 브라우저로 열고, 끄면 클립보드에 복사합니다."}},"nl":{"stringUnit":{"state":"translated","value":"Beschikbaar wanneer Ontvangen zonder vragen aan staat. Ingeschakeld openen URL's van Android direct in je standaardbrowser; uitgeschakeld worden ze naar het klembord gekopieerd."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Disponível quando Receber sem perguntar está ativado. Ativado, URLs do Android abrem imediatamente no navegador padrão; desativado, são copiadas para a área de transferência."}},"pt-PT":{"stringUnit":{"state":"translated","value":"Disponível quando Receber sem perguntar está ativado. Ativado, os URLs do Android abrem imediatamente no navegador predefinido; desativado, são copiados para a área de transferência."}},"ro":{"stringUnit":{"state":"translated","value":"Disponibil când Primește fără confirmare este activat. Când este activat, URL-urile de pe Android se deschid imediat în browserul implicit; când este dezactivat, sunt copiate în clipboard."}},"ru":{"stringUnit":{"state":"translated","value":"Доступно, когда включено Получать без подтверждения. Если включено, URL с Android сразу открываются в браузере по умолчанию; если выключено, копируются в буфер обмена."}},"th":{"stringUnit":{"state":"translated","value":"ใช้ได้เมื่อเปิดรับโดยไม่ถาม เมื่อเปิด URL จาก Android จะเปิดทันทีในเบราว์เซอร์เริ่มต้น เมื่อปิด URL จะถูกคัดลอกไปยังคลิปบอร์ด"}},"uk":{"stringUnit":{"state":"translated","value":"Доступно, коли ввімкнено Отримувати без підтвердження. Якщо ввімкнено, URL з Android одразу відкриваються у браузері за замовчуванням; якщо вимкнено, копіюються до буфера обміну."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"在开启无需确认接收时可用。开启后，来自 Android 的 URL 会立即用默认浏览器打开；关闭时会复制到剪贴板。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"在開啟無需確認接收時可用。開啟後，來自 Android 的 URL 會立即用預設瀏覽器開啟；關閉時會複製到剪貼簿。"}}}},
    "Cancel": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"إلغاء"}},"de":{"stringUnit":{"state":"translated","value":"Abbrechen"}},"en":{"stringUnit":{"state":"translated","value":"Cancel"}},"es":{"stringUnit":{"state":"translated","value":"Cancelar"}},"fr":{"stringUnit":{"state":"translated","value":"Annuler"}},"hu":{"stringUnit":{"state":"translated","value":"Mégse"}},"it":{"stringUnit":{"state":"translated","value":"Annulla"}},"ja":{"stringUnit":{"state":"translated","value":"キャンセル"}},"ko":{"stringUnit":{"state":"translated","value":"취소"}},"nl":{"stringUnit":{"state":"translated","value":"Annuleren"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Cancelar"}},"pt-PT":{"stringUnit":{"state":"translated","value":"Cancelar"}},"ro":{"stringUnit":{"state":"translated","value":"Anulați"}},"ru":{"stringUnit":{"state":"translated","value":"Отмена"}},"th":{"stringUnit":{"state":"translated","value":"ยกเลิก"}},"uk":{"stringUnit":{"state":"translated","value":"Скасувати"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"取消"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"取消"}}}},
    "UpgradeToPlus": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"الترقية إلى Pyonta+…"}},"de":{"stringUnit":{"state":"translated","value":"Auf Pyonta+ upgraden…"}},"en":{"stringUnit":{"state":"translated","value":"Upgrade to Pyonta+…"}},"es":{"stringUnit":{"state":"translated","value":"Actualizar a Pyonta+…"}},"fr":{"stringUnit":{"state":"translated","value":"Passer à Pyonta+…"}},"hu":{"stringUnit":{"state":"translated","value":"Frissítés Pyonta+-ra…"}},"it":{"stringUnit":{"state":"translated","value":"Passa a Pyonta+…"}},"ja":{"stringUnit":{"state":"translated","value":"Pyonta+ にアップグレード…"}},"ko":{"stringUnit":{"state":"translated","value":"Pyonta+로 업그레이드…"}},"nl":{"stringUnit":{"state":"translated","value":"Upgrade naar Pyonta+…"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Fazer upgrade para Pyonta+…"}},"pt-PT":{"stringUnit":{"state":"translated","value":"Atualizar para Pyonta+…"}},"ro":{"stringUnit":{"state":"translated","value":"Upgrade la Pyonta+…"}},"ru":{"stringUnit":{"state":"translated","value":"Перейти на Pyonta+…"}},"th":{"stringUnit":{"state":"translated","value":"อัปเกรดเป็น Pyonta+…"}},"uk":{"stringUnit":{"state":"translated","value":"Оновити до Pyonta+…"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"升级到 Pyonta+…"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"升級到 Pyonta+…"}}}},
    "UpgradeToPlus.Title": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"الترقية إلى Pyonta+"}},"de":{"stringUnit":{"state":"translated","value":"Auf Pyonta+ upgraden"}},"en":{"stringUnit":{"state":"translated","value":"Upgrade to Pyonta+"}},"es":{"stringUnit":{"state":"translated","value":"Actualizar a Pyonta+"}},"fr":{"stringUnit":{"state":"translated","value":"Passer à Pyonta+"}},"hu":{"stringUnit":{"state":"translated","value":"Frissítés Pyonta+-ra"}},"it":{"stringUnit":{"state":"translated","value":"Passa a Pyonta+"}},"ja":{"stringUnit":{"state":"translated","value":"Pyonta+ にアップグレード"}},"ko":{"stringUnit":{"state":"translated","value":"Pyonta+로 업그레이드"}},"nl":{"stringUnit":{"state":"translated","value":"Upgrade naar Pyonta+"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Fazer upgrade para Pyonta+"}},"pt-PT":{"stringUnit":{"state":"translated","value":"Atualizar para Pyonta+"}},"ro":{"stringUnit":{"state":"translated","value":"Upgrade la Pyonta+"}},"ru":{"stringUnit":{"state":"translated","value":"Перейти на Pyonta+"}},"th":{"stringUnit":{"state":"translated","value":"อัปเกรดเป็น Pyonta+"}},"uk":{"stringUnit":{"state":"translated","value":"Оновити до Pyonta+"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"升级到 Pyonta+"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"升級到 Pyonta+"}}}},
    "RestorePurchases": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"استعادة المشتريات…"}},"de":{"stringUnit":{"state":"translated","value":"Käufe wiederherstellen…"}},"en":{"stringUnit":{"state":"translated","value":"Restore purchases…"}},"es":{"stringUnit":{"state":"translated","value":"Restaurar compras…"}},"fr":{"stringUnit":{"state":"translated","value":"Restaurer les achats…"}},"hu":{"stringUnit":{"state":"translated","value":"Vásárlások visszaállítása…"}},"it":{"stringUnit":{"state":"translated","value":"Ripristina acquisti…"}},"ja":{"stringUnit":{"state":"translated","value":"購入を復元…"}},"ko":{"stringUnit":{"state":"translated","value":"구입 항목 복원…"}},"nl":{"stringUnit":{"state":"translated","value":"Aankopen herstellen…"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Restaurar compras…"}},"pt-PT":{"stringUnit":{"state":"translated","value":"Restaurar compras…"}},"ro":{"stringUnit":{"state":"translated","value":"Restaurați achizițiile…"}},"ru":{"stringUnit":{"state":"translated","value":"Восстановить покупки…"}},"th":{"stringUnit":{"state":"translated","value":"กู้คืนการซื้อ…"}},"uk":{"stringUnit":{"state":"translated","value":"Відновити покупки…"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"恢复购买…"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"恢復購買…"}}}},
    "PlusRequired.Message": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"يتطلب الاستلام من Android اشتراك Pyonta+. قم بالترقية، ثم اطلب من المرسل المحاولة مرة أخرى."}},"de":{"stringUnit":{"state":"translated","value":"Für den Empfang von Android ist Pyonta+ erforderlich. Führe ein Upgrade durch und bitte den Absender, es erneut zu versuchen."}},"en":{"stringUnit":{"state":"translated","value":"Receiving from Android requires Pyonta+. Upgrade, then ask the sender to try again."}},"es":{"stringUnit":{"state":"translated","value":"Recibir desde Android requiere Pyonta+. Actualiza y pide al remitente que lo intente de nuevo."}},"fr":{"stringUnit":{"state":"translated","value":"La réception depuis Android nécessite Pyonta+. Passez à la version supérieure, puis demandez à l’expéditeur de réessayer."}},"hu":{"stringUnit":{"state":"translated","value":"Az Androidról való fogadáshoz Pyonta+ szükséges. Frissíts, majd kérd meg a küldőt, hogy próbálja újra."}},"it":{"stringUnit":{"state":"translated","value":"La ricezione da Android richiede Pyonta+. Esegui l’upgrade, poi chiedi al mittente di riprovare."}},"ja":{"stringUnit":{"state":"translated","value":"Android から受信するには Pyonta+ が必要です。アップグレード後、もう一度送信してもらってください。"}},"ko":{"stringUnit":{"state":"translated","value":"Android에서 받으려면 Pyonta+가 필요합니다. 업그레이드한 뒤 보낸 사람에게 다시 시도해 달라고 하세요."}},"nl":{"stringUnit":{"state":"translated","value":"Ontvangen vanaf Android vereist Pyonta+. Upgrade en vraag de afzender het opnieuw te proberen."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Receber do Android requer Pyonta+. Faça upgrade e peça ao remetente para tentar novamente."}},"pt-PT":{"stringUnit":{"state":"translated","value":"Receber do Android requer Pyonta+. Atualize e peça ao remetente para tentar novamente."}},"ro":{"stringUnit":{"state":"translated","value":"Primirea de pe Android necesită Pyonta+. Faceți upgrade, apoi cereți expeditorului să încerce din nou."}},"ru":{"stringUnit":{"state":"translated","value":"Для получения с Android требуется Pyonta+. Перейдите на Pyonta+, затем попросите отправителя повторить попытку."}},"th":{"stringUnit":{"state":"translated","value":"การรับจาก Android ต้องใช้ Pyonta+ โปรดอัปเกรด แล้วขอให้ผู้ส่งลองอีกครั้ง"}},"uk":{"stringUnit":{"state":"translated","value":"Для отримання з Android потрібен Pyonta+. Оновіть, а потім попросіть відправника спробувати ще раз."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"从 Android 接收需要 Pyonta+。升级后,请让发送者再试一次。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"從 Android 接收需要 Pyonta+。升級後,請讓傳送者再試一次。"}}}},
    "PlusUnavailable.Message": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"لم يتم إعداد Pyonta+ بعد. أضف مفتاح RevenueCat العام قبل إصدار هذا البناء."}},"de":{"stringUnit":{"state":"translated","value":"Pyonta+ ist noch nicht konfiguriert. Füge vor der Veröffentlichung dieses Builds den öffentlichen RevenueCat-API-Schlüssel hinzu."}},"en":{"stringUnit":{"state":"translated","value":"Pyonta+ is not configured yet. Add the RevenueCat public API key before releasing this build."}},"es":{"stringUnit":{"state":"translated","value":"Pyonta+ aún no está configurado. Añade la clave API pública de RevenueCat antes de publicar esta compilación."}},"fr":{"stringUnit":{"state":"translated","value":"Pyonta+ n’est pas encore configuré. Ajoutez la clé API publique RevenueCat avant de publier cette build."}},"hu":{"stringUnit":{"state":"translated","value":"A Pyonta+ még nincs beállítva. A build kiadása előtt add hozzá a RevenueCat nyilvános API-kulcsát."}},"it":{"stringUnit":{"state":"translated","value":"Pyonta+ non è ancora configurato. Aggiungi la chiave API pubblica di RevenueCat prima di rilasciare questa build."}},"ja":{"stringUnit":{"state":"translated","value":"Pyonta+ はまだ設定されていません。リリース前に RevenueCat の public API key を設定してください。"}},"ko":{"stringUnit":{"state":"translated","value":"Pyonta+가 아직 설정되지 않았습니다. 이 빌드를 출시하기 전에 RevenueCat 공개 API 키를 추가하세요."}},"nl":{"stringUnit":{"state":"translated","value":"Pyonta+ is nog niet geconfigureerd. Voeg de openbare RevenueCat API-sleutel toe voordat je deze build uitbrengt."}},"pt-BR":{"stringUnit":{"state":"translated","value":"O Pyonta+ ainda não está configurado. Adicione a chave de API pública da RevenueCat antes de lançar esta build."}},"pt-PT":{"stringUnit":{"state":"translated","value":"O Pyonta+ ainda não está configurado. Adicione a chave API pública da RevenueCat antes de lançar esta build."}},"ro":{"stringUnit":{"state":"translated","value":"Pyonta+ nu este configurat încă. Adăugați cheia API publică RevenueCat înainte de lansarea acestui build."}},"ru":{"stringUnit":{"state":"translated","value":"Pyonta+ еще не настроен. Добавьте публичный API-ключ RevenueCat перед выпуском этой сборки."}},"th":{"stringUnit":{"state":"translated","value":"ยังไม่ได้ตั้งค่า Pyonta+ โปรดเพิ่ม public API key ของ RevenueCat ก่อนปล่อยบิลด์นี้"}},"uk":{"stringUnit":{"state":"translated","value":"Pyonta+ ще не налаштовано. Додайте публічний API-ключ RevenueCat перед випуском цієї збірки."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"Pyonta+ 尚未配置。发布此构建前,请添加 RevenueCat public API key。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"Pyonta+ 尚未設定。發布此建置前,請加入 RevenueCat public API key。"}}}},
    "PlusNoOfferings.Message": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"لا تتوفر منتجات Pyonta+ بعد. تحقق من إعدادات RevenueCat offering ومنتجات App Store Connect."}},"de":{"stringUnit":{"state":"translated","value":"Es sind noch keine Pyonta+-Produkte verfügbar. Prüfe das RevenueCat-Offering und die Produkteinstellungen in App Store Connect."}},"en":{"stringUnit":{"state":"translated","value":"No Pyonta+ products are available yet. Check the RevenueCat offering and App Store Connect product setup."}},"es":{"stringUnit":{"state":"translated","value":"Aún no hay productos de Pyonta+ disponibles. Revisa el offering de RevenueCat y la configuración de productos en App Store Connect."}},"fr":{"stringUnit":{"state":"translated","value":"Aucun produit Pyonta+ n’est encore disponible. Vérifiez l’offering RevenueCat et la configuration des produits dans App Store Connect."}},"hu":{"stringUnit":{"state":"translated","value":"Még nem érhetők el Pyonta+ termékek. Ellenőrizd a RevenueCat offeringet és az App Store Connect termékbeállításait."}},"it":{"stringUnit":{"state":"translated","value":"Non sono ancora disponibili prodotti Pyonta+. Controlla l’offering RevenueCat e la configurazione dei prodotti in App Store Connect."}},"ja":{"stringUnit":{"state":"translated","value":"Pyonta+ の商品がまだ取得できません。RevenueCat の offering と App Store Connect の商品設定を確認してください。"}},"ko":{"stringUnit":{"state":"translated","value":"Pyonta+ 상품을 아직 사용할 수 없습니다. RevenueCat offering과 App Store Connect 상품 설정을 확인하세요."}},"nl":{"stringUnit":{"state":"translated","value":"Er zijn nog geen Pyonta+-producten beschikbaar. Controleer de RevenueCat-offering en de productinstellingen in App Store Connect."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Ainda não há produtos Pyonta+ disponíveis. Verifique a offering da RevenueCat e a configuração de produtos no App Store Connect."}},"pt-PT":{"stringUnit":{"state":"translated","value":"Ainda não há produtos Pyonta+ disponíveis. Verifique a offering da RevenueCat e a configuração de produtos no App Store Connect."}},"ro":{"stringUnit":{"state":"translated","value":"Nu există încă produse Pyonta+ disponibile. Verificați offering-ul RevenueCat și configurarea produselor în App Store Connect."}},"ru":{"stringUnit":{"state":"translated","value":"Продукты Pyonta+ пока недоступны. Проверьте offering в RevenueCat и настройки продуктов в App Store Connect."}},"th":{"stringUnit":{"state":"translated","value":"ยังไม่มีสินค้า Pyonta+ ให้ใช้งาน โปรดตรวจสอบ offering ใน RevenueCat และการตั้งค่าสินค้าใน App Store Connect"}},"uk":{"stringUnit":{"state":"translated","value":"Продукти Pyonta+ ще недоступні. Перевірте offering у RevenueCat і налаштування продуктів в App Store Connect."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"尚无可用的 Pyonta+ 商品。请检查 RevenueCat offering 和 App Store Connect 商品设置。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"尚無可用的 Pyonta+ 商品。請檢查 RevenueCat offering 和 App Store Connect 商品設定。"}}}},
    "PlusPurchaseSuccess.Message": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"Pyonta+ نشط. تم فتح الاستلام من Android الآن."}},"de":{"stringUnit":{"state":"translated","value":"Pyonta+ ist aktiv. Der Empfang von Android ist jetzt freigeschaltet."}},"en":{"stringUnit":{"state":"translated","value":"Pyonta+ is active. Receiving from Android is now unlocked."}},"es":{"stringUnit":{"state":"translated","value":"Pyonta+ está activo. La recepción desde Android ya está desbloqueada."}},"fr":{"stringUnit":{"state":"translated","value":"Pyonta+ est actif. La réception depuis Android est maintenant déverrouillée."}},"hu":{"stringUnit":{"state":"translated","value":"A Pyonta+ aktív. Az Androidról való fogadás mostantól fel van oldva."}},"it":{"stringUnit":{"state":"translated","value":"Pyonta+ è attivo. La ricezione da Android è ora sbloccata."}},"ja":{"stringUnit":{"state":"translated","value":"Pyonta+ が有効になりました。Android からの受信が使えるようになりました。"}},"ko":{"stringUnit":{"state":"translated","value":"Pyonta+가 활성화되었습니다. 이제 Android에서 받을 수 있습니다."}},"nl":{"stringUnit":{"state":"translated","value":"Pyonta+ is actief. Ontvangen vanaf Android is nu ontgrendeld."}},"pt-BR":{"stringUnit":{"state":"translated","value":"O Pyonta+ está ativo. Receber do Android agora está desbloqueado."}},"pt-PT":{"stringUnit":{"state":"translated","value":"O Pyonta+ está ativo. Receber do Android está agora desbloqueado."}},"ro":{"stringUnit":{"state":"translated","value":"Pyonta+ este activ. Primirea de pe Android este acum deblocată."}},"ru":{"stringUnit":{"state":"translated","value":"Pyonta+ активен. Получение с Android теперь разблокировано."}},"th":{"stringUnit":{"state":"translated","value":"Pyonta+ เปิดใช้งานแล้ว ตอนนี้รับจาก Android ได้แล้ว"}},"uk":{"stringUnit":{"state":"translated","value":"Pyonta+ активний. Отримання з Android тепер розблоковано."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"Pyonta+ 已激活。现在可以从 Android 接收了。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"Pyonta+ 已啟用。現在可以從 Android 接收了。"}}}},
    "PlusRestoreSuccess.Message": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"تمت استعادة المشتريات. Pyonta+ نشط."}},"de":{"stringUnit":{"state":"translated","value":"Käufe wurden wiederhergestellt. Pyonta+ ist aktiv."}},"en":{"stringUnit":{"state":"translated","value":"Purchases restored. Pyonta+ is active."}},"es":{"stringUnit":{"state":"translated","value":"Compras restauradas. Pyonta+ está activo."}},"fr":{"stringUnit":{"state":"translated","value":"Achats restaurés. Pyonta+ est actif."}},"hu":{"stringUnit":{"state":"translated","value":"A vásárlások visszaállítva. A Pyonta+ aktív."}},"it":{"stringUnit":{"state":"translated","value":"Acquisti ripristinati. Pyonta+ è attivo."}},"ja":{"stringUnit":{"state":"translated","value":"購入を復元しました。Pyonta+ が有効です。"}},"ko":{"stringUnit":{"state":"translated","value":"구입 항목을 복원했습니다. Pyonta+가 활성화되었습니다."}},"nl":{"stringUnit":{"state":"translated","value":"Aankopen hersteld. Pyonta+ is actief."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Compras restauradas. O Pyonta+ está ativo."}},"pt-PT":{"stringUnit":{"state":"translated","value":"Compras restauradas. O Pyonta+ está ativo."}},"ro":{"stringUnit":{"state":"translated","value":"Achizițiile au fost restaurate. Pyonta+ este activ."}},"ru":{"stringUnit":{"state":"translated","value":"Покупки восстановлены. Pyonta+ активен."}},"th":{"stringUnit":{"state":"translated","value":"กู้คืนการซื้อแล้ว Pyonta+ เปิดใช้งานอยู่"}},"uk":{"stringUnit":{"state":"translated","value":"Покупки відновлено. Pyonta+ активний."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"购买已恢复。Pyonta+ 已激活。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"購買已恢復。Pyonta+ 已啟用。"}}}},
    "PlusRestoreMissing.Message": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"لم يتم العثور على عملية شراء Pyonta+ نشطة لهذا Apple ID."}},"de":{"stringUnit":{"state":"translated","value":"Für diese Apple-ID wurde kein aktiver Pyonta+-Kauf gefunden."}},"en":{"stringUnit":{"state":"translated","value":"No active Pyonta+ purchase was found for this Apple ID."}},"es":{"stringUnit":{"state":"translated","value":"No se encontró ninguna compra activa de Pyonta+ para este Apple ID."}},"fr":{"stringUnit":{"state":"translated","value":"Aucun achat Pyonta+ actif n’a été trouvé pour cet identifiant Apple."}},"hu":{"stringUnit":{"state":"translated","value":"Ehhez az Apple ID-hez nem található aktív Pyonta+ vásárlás."}},"it":{"stringUnit":{"state":"translated","value":"Non è stato trovato alcun acquisto Pyonta+ attivo per questo Apple ID."}},"ja":{"stringUnit":{"state":"translated","value":"この Apple ID で有効な Pyonta+ の購入は見つかりませんでした。"}},"ko":{"stringUnit":{"state":"translated","value":"이 Apple ID에서 활성화된 Pyonta+ 구입 항목을 찾을 수 없습니다."}},"nl":{"stringUnit":{"state":"translated","value":"Er is geen actieve Pyonta+-aankoop gevonden voor deze Apple ID."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Nenhuma compra ativa do Pyonta+ foi encontrada para este Apple ID."}},"pt-PT":{"stringUnit":{"state":"translated","value":"Nenhuma compra ativa do Pyonta+ foi encontrada para este Apple ID."}},"ro":{"stringUnit":{"state":"translated","value":"Nu a fost găsită nicio achiziție Pyonta+ activă pentru acest Apple ID."}},"ru":{"stringUnit":{"state":"translated","value":"Для этого Apple ID не найдена активная покупка Pyonta+."}},"th":{"stringUnit":{"state":"translated","value":"ไม่พบการซื้อ Pyonta+ ที่ใช้งานอยู่สำหรับ Apple ID นี้"}},"uk":{"stringUnit":{"state":"translated","value":"Для цього Apple ID не знайдено активної покупки Pyonta+."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"未找到此 Apple ID 的有效 Pyonta+ 购买。"}},"zh-Hant":{"stri