    "NotificationsDenied.Message": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج Pyonta إلى القدرة على عرض الإشعارات لنقل الملفات الواردة. يرجى السماح بالإشعارات في إعدادات النظام."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta трябва да показва известия за входящи файлови трансфери. Разрешете известията в System Settings."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আসা ফাইল ট্রান্সফারের জন্য Pyonta-কে নোটিফিকেশন দেখাতে হবে। System Settings-এ নোটিফিকেশন অনুমতি দিন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta ha de poder mostrar notificacions per a transferències entrants. Permet les notificacions a la Configuració del sistema."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta musí zobrazovat oznámení pro příchozí přenosy souborů. Povolte oznámení v Nastavení systému."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta skal kunne vise notifikationer for indgående filoverførsler. Tillad notifikationer i Systemindstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta benötigt die Erlaubnis Mitteilungen für eingehende Datenransfers anzuzeigen. Bitte erlaube Mitteilungen in den Systemeinstellungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Pyonta πρέπει να εμφανίζει ειδοποιήσεις για εισερχόμενες μεταφορές αρχείων. Επιτρέψτε τις ειδοποιήσεις στις Ρυθμίσεις συστήματος."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Pyonta needs to be able to display notifications for incoming file transfers. Please allow notifications in System Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta necesita poder mostrar notificaciones para las transferencias de archivos entrantes. Permita las notificaciones en la configuración del sistema."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta peab saama kuvada teavitusi sissetulevate failiedastuste kohta. Lubage teavitused Süsteemiseadetes."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyontan täytyy voida näyttää ilmoituksia saapuvista tiedostonsiirroista. Salli ilmoitukset Järjestelmäasetuksissa."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Kailangang makapagpakita ang Pyonta ng mga notification para sa papasok na file transfer. Payagan ang notifications sa System Settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta doit pouvoir afficher des notifications pour les transferts de fichiers entrants. Veuillez autoriser les notifications dans les paramètres système."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta צריך להציג התראות עבור העברות קבצים נכנסות. אפשר התראות בהגדרות המערכת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आने वाले फ़ाइल ट्रांसफर के लिए Pyonta को नोटिफिकेशन दिखाने की जरूरत है। System Settings में नोटिफिकेशन की अनुमति दें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta mora moći prikazivati obavijesti za dolazne prijenose datoteka. Dopustite obavijesti u Postavkama sustava."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pyonta-nak szüksége van értesítéseket küldeni a bejövő fájlok fogadásához. Kérlek engedélyezd az értesítésekhez való hozzáférést a Rendszerbeállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta perlu menampilkan notifikasi untuk transfer file masuk. Izinkan notifikasi di Pengaturan Sistem."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta deve essere in grado di visualizzare le notifiche per i trasferimenti di file in entrata. Consenti le notifiche nelle Impostazioni di sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyontaでファイル受信の通知を表示できる必要があります。システム設定で通知を許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta에서 파일 수신에 대한 알림을 표시할 수 있어야 합니다. 시스템 설정에서 알림을 허용하세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta turi rodyti pranešimus apie gaunamus failų perkėlimus. Leiskite pranešimus Sistemos nustatymuose."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta jāspēj rādīt paziņojumus par ienākošām failu pārsūtīšanām. Atļaujiet paziņojumus Sistēmas iestatījumos."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta perlu memaparkan pemberitahuan untuk pemindahan fail masuk. Benarkan pemberitahuan dalam Tetapan Sistem."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta må kunne vise varsler for innkommende filoverføringer. Tillat varsler i Systeminnstillinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta moet meldingen kunnen weergeven voor inkomende bestandsoverdrachten. Sta meldingen toe in de systeeminstellingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta musi wyświetlać powiadomienia o przychodzących transferach plików. Zezwól na powiadomienia w Ustawieniach systemowych."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pyonta precisa ser capaz de exibir notificações para o recebimento de arquivos. Por favor, habilite as notificações em Ajustes do Sistema."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pyonta precisa ser capaz de mostrar notificações para receber ficheiros. Por favor, active as notificações em Definições do Sistema."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta trebuie să poată afișa notificări pentru transferurile de fișiere primite. Vă rugăm să permiteți notificările în Setările Sistemului."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta необходима возможность показывать уведомления о входящих файлах. Пожалуйста, разрешите уведомления в Системных настройках."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta musí zobrazovať oznámenia pre prichádzajúce prenosy súborov. Povoľte oznámenia v Systémových nastaveniach."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta mora prikazovati obvestila za dohodne prenose datotek. Dovolite obvestila v Sistemskih nastavitvah."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta мора да приказује обавештења за долазне преносе датотека. Дозволите обавештења у System Settings."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta behöver kunna visa aviseringar för inkommande filöverföringar. Tillåt aviseringar i Systeminställningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta ไม่สามารถแสดงการแจ้งเตือนไฟล์ที่เข้ามาได้ โปรดให้สิทธิ์การแจ้งเตือน ในการตั้งค่าระบบ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta'nın gelen dosya aktarımları için bildirim gösterebilmesi gerekir. Sistem Ayarları'nda bildirimlere izin verin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta потрібна можливість показувати сповіщення про вхідні файли. Будь ласка, дозвольте сповіщення у Системних налаштуваннях."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta cần hiển thị thông báo cho các lượt chuyển tệp đến. Hãy cho phép thông báo trong Cài đặt hệ thống."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta 需显示是否接收文件传输的通知。请在 系统设置 中允许通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta 需要顯示檔案傳入的通知，請在系統設定中允許通知。"
          }
        }
      }
    },
