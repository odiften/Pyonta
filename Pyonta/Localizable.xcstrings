    "ClipboardEmpty.Body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انسخ بعض النص أولاً، ثم حاول مرة أخرى."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Първо копирайте текст и опитайте отново."
