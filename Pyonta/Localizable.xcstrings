    "VisibleToEveryone.Tooltip": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند الإيقاف، يتم إخفاء جهاز Mac الخاص بك من Quick Share. الإرسال إلى الأجهزة الأخرى يستمر بالعمل."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Когато е изключено, вашият Mac е скрит от Quick Share. Изпращането към други устройства продължава да работи."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "বন্ধ থাকলে Quick Share-এ আপনার Mac দেখা যাবে না। অন্য ডিভাইসে পাঠানো তবু কাজ করবে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Quan és desactivat, el teu Mac queda ocult a Quick Share. Enviar a altres dispositius continua funcionant."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Když je vypnuto, váš Mac je v Quick Share skrytý. Odesílání do jiných zařízení stále funguje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når dette er slået fra, er din Mac skjult for Quick Share. Afsendelse til andre enheder virker stadig."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deaktiviert, ist dein Mac für Quick Share verborgen. Das Senden an andere Geräte funktioniert weiterhin."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Όταν είναι ανενεργό, το Mac σας κρύβεται από το Quick Share. Η αποστολή σε άλλες συσκευές εξακολουθεί να λειτουργεί."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, your Mac is hidden from Quick Share. Sending to other devices still works."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está desactivado, tu Mac está oculto en Quick Share. Sigue siendo posible enviar a otros dispositivos."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kui see on väljas, on teie Mac Quick Share'is peidetud. Teistesse seadmetesse saatmine töötab endiselt."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun tämä ei ole käytössä, Macisi on piilotettu Quick Sharelta. Lähettäminen muihin laitteisiin toimii edelleen."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapag naka-off, nakatago ang iyong Mac sa Quick Share. Gumagana pa rin ang pagpapadala sa ibang device."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est désactivée, votre Mac est masqué dans Quick Share. L'envoi vers d'autres appareils fonctionne toujours."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כאשר כבוי, ה-Mac שלך מוסתר מ-Quick Share. שליחה למכשירים אחרים עדיין עובדת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बंद होने पर आपका Mac Quick Share से छिपा रहता है। दूसरे डिवाइस पर भेजना फिर भी काम करता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kada je isključeno, vaš Mac je skriven u Quick Shareu. Slanje na druge uređaje i dalje radi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kikapcsolt állapotban a Mac-et nem látja a Quick Share. A más eszközökre küldés továbbra is működik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika nonaktif, Mac Anda disembunyikan dari Quick Share. Mengirim ke perangkat lain tetap berfungsi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando disattivato, il tuo Mac è nascosto in Quick Share. L'invio ad altri dispositivi funziona ancora."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフのとき、Quick Share からこの Mac は見えなくなります。他のデバイスへの送信は引き続き可能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "꺼져 있으면 Quick Share에서 이 Mac이 보이지 않습니다. 다른 기기로 보내는 것은 계속 작동합니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Kai išjungta, jūsų Mac yra paslėptas nuo Quick Share. Siuntimas į kitus įrenginius vis tiek veikia."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kad izslēgts, jūsu Mac ir paslēpts no Quick Share. Sūtīšana uz citām ierīcēm joprojām darbojas."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Apabila dimatikan, Mac anda tersembunyi daripada Quick Share. Menghantar ke peranti lain masih berfungsi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Når dette er av, skjules Macen din for Quick Share. Sending til andre enheter fungerer fortsatt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Indien uitgeschakeld is uw Mac verborgen voor Quick Share. Verzenden naar andere apparaten blijft werken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdy wyłączone, Twój Mac jest ukryty w Quick Share. Wysyłanie do innych urządzeń nadal działa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando desativado, seu Mac fica oculto no Quick Share. O envio para outros dispositivos continua funcionando."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando desativado, o seu Mac fica oculto no Quick Share. O envio para outros dispositivos continua a funcionar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Când este dezactivat, Mac-ul dvs. este ascuns de Quick Share. Trimiterea către alte dispozitive funcționează în continuare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда выключено, ваш Mac скрыт от Quick Share. Отправка на другие устройства продолжает работать."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Keď je vypnuté, váš Mac je v Quick Share skrytý. Odosielanie do iných zariadení stále funguje."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko je izklopljeno, je vaš Mac skrit pred Quick Share. Pošiljanje v druge naprave še vedno deluje."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Када је искључено, ваш Mac је сакривен у Quick Share-у. Слање на друге уређаје и даље ради."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "När detta är av är din Mac dold för Quick Share. Det går fortfarande att skicka till andra enheter."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เมื่อปิด Mac ของคุณจะถูกซ่อนจาก Quick Share การส่งไปยังอุปกรณ์อื่นยังคงใช้งานได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapalıyken Mac'iniz Quick Share'de gizlenir. Diğer aygıtlara gönderme çalışmaya devam eder."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коли вимкнено, ваш Mac прихований від Quick Share. Надсилання на інші пристрої продовжує працювати."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khi tắt, Mac của bạn bị ẩn khỏi Quick Share. Gửi đến thiết bị khác vẫn hoạt động."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后，您的 Mac 在 Quick Share 中将被隐藏。向其他设备发送仍然可用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉後，您的 Mac 在 Quick Share 中將被隱藏。向其他裝置傳送仍可用。"
          }
        }
      }
    }
  },
  "version": "1.0"
