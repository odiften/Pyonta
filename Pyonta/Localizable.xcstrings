    "AutoAcceptFiles": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"الاستلام دون سؤال"}},"de":{"stringUnit":{"state":"translated","value":"Ohne Nachfrage empfangen"}},"en":{"stringUnit":{"state":"translated","value":"Receive without asking"}},"es":{"stringUnit":{"state":"translated","value":"Recibir sin preguntar"}},"fr":{"stringUnit":{"state":"translated","value":"Recevoir sans demander"}},"hu":{"stringUnit":{"state":"translated","value":"Fogadás kérdés nélkül"}},"it":{"stringUnit":{"state":"translated","value":"Ricevi senza chiedere"}},"ja":{"stringUnit":{"state":"translated","value":"確認なしで受信"}},"ko":{"stringUnit":{"state":"translated","value":"확인 없이 받기"}},"nl":{"stringUnit":{"state":"translated","value":"Ontvangen zonder vragen"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Receber sem perguntar"}},"pt-PT":{"stringUnit":{"state":"translated","value":"Receber sem perguntar"}},"ro":{"stringUnit":{"state":"translated","value":"Primește fără confirmare"}},"ru":{"stringUnit":{"state":"translated","value":"Получать без подтверждения"}},"th":{"stringUnit":{"state":"translated","value":"รับโดยไม่ถาม"}},"uk":{"stringUnit":{"state":"translated","value":"Отримувати без підтвердження"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"无需确认接收"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"無需確認接收"}}}},
    "AutoAcceptFiles.Tooltip": {"extractionState":"manual","localizations":{"ar":{"stringUnit":{"state":"translated","value":"عند التفعيل، تُقبل الملفات والنصوص وعناوين URL من Android دون سؤال. إذا كان فتح عناوين URL مفعّلًا أيضًا، قد تُفتح عناوين URL فورًا."}},"de":{"stringUnit":{"state":"translated","value":"Wenn aktiviert, werden Dateien, Text und URLs von Android ohne Nachfrage angenommen. Ist das Öffnen von URLs ebenfalls aktiviert, können empfangene URLs sofort geöffnet werden."}},"en":{"stringUnit":{"state":"translated","value":"When on, files, text, and URLs from Android are accepted without asking. If URL opening is also on, received URLs can open immediately."}},"es":{"stringUnit":{"state":"translated","value":"Cuando está activado, archivos, texto y URLs de Android se aceptan sin preguntar. Si abrir URLs también está activado, las URLs recibidas pueden abrirse de inmediato."}},"fr":{"stringUnit":{"state":"translated","value":"Si activé, les fichiers, textes et URL venant d’Android sont acceptés sans demande. Si l’ouverture des URL est aussi activée, les URL reçues peuvent s’ouvrir immédiatement."}},"hu":{"stringUnit":{"state":"translated","value":"Bekapcsolva az Androidról érkező fájlok, szövegek és URL-ek kérdés nélkül elfogadásra kerülnek. Ha az URL-ek megnyitása is be van kapcsolva, a fogadott URL-ek azonnal megnyílhatnak."}},"it":{"stringUnit":{"state":"translated","value":"Se attivo, file, testo e URL da Android vengono accettati senza chiedere. Se è attiva anche l’apertura degli URL, gli URL ricevuti possono aprirsi subito."}},"ja":{"stringUnit":{"state":"translated","value":"オンのとき、Android からのファイル・テキスト・URLを確認なしで受信します。「URLを自動で開く」もオンの場合、URLはすぐブラウザで開きます。"}},"ko":{"stringUnit":{"state":"translated","value":"켜져 있으면 Android에서 온 파일, 텍스트, URL을 확인 없이 받습니다. URL 열기도 켜져 있으면 받은 URL이 즉시 열릴 수 있습니다."}},"nl":{"stringUnit":{"state":"translated","value":"Wanneer ingeschakeld, worden bestanden, tekst en URL's vanaf Android zonder vragen geaccepteerd. Als URL's openen ook aan staat, kunnen ontvangen URL's direct openen."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Quando ativado, arquivos, textos e URLs do Android são aceitos sem perguntar. Se abrir URLs também estiver ativado, URLs recebidas podem abrir imediatamente."}},"pt-PT":{"stringUnit":{"state":"translated","value":"Quando ativado, ficheiros, texto e URLs do Android são aceites sem perguntar. Se a abertura de URLs também estiver ativada, os URLs recebidos podem abrir imediatamente."}},"ro":{"stringUnit":{"state":"translated","value":"Când este activat, fișierele, textul și URL-urile de pe Android sunt acceptate fără întrebare. Dacă deschiderea URL-urilor este și ea activată, URL-urile primite se pot deschide imediat."}},"ru":{"stringUnit":{"state":"translated","value":"Когда включено, файлы, текст и URL с Android принимаются без запроса. Если открытие URL тоже включено, полученные URL могут открываться сразу."}},"th":{"stringUnit":{"state":"translated","value":"เมื่อเปิด ไฟล์ ข้อความ และ URL จาก Android จะถูกรับโดยไม่ถาม หากเปิดการเปิด URL ด้วย URL ที่ได้รับอาจเปิดทันที"}},"uk":{"stringUnit":{"state":"translated","value":"Коли ввімкнено, файли, текст і URL з Android приймаються без запиту. Якщо відкривання URL також увімкнено, отримані URL можуть відкриватися одразу."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"开启时，来自 Android 的文件、文本和 URL 会无需确认接收。如果也开启了打开 URL，收到的 URL 可能会立即打开。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"開啟時，來自 Android 的檔案、文字和 URL 會無需確認接收。如果也開啟了開啟 URL，收到的 URL 可能會立即開啟。"}}}},
