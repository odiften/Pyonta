    "SendError.RetryQuickShare": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر على Quick Share إكمال النقل. افتح Quick Share على جهاز Android وحاول مرة أخرى."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share не успя да завърши трансфера. Отворете Quick Share на Android устройството и опитайте отново."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share ট্রান্সফার শেষ করতে পারেনি। Android ডিভাইসে Quick Share খুলে আবার চেষ্টা করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share no ha pogut completar la transferència. Obre Quick Share al dispositiu Android i torna-ho a provar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share nemohl přenos dokončit. Otevřete Quick Share na zařízení Android a zkuste to znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share kunne ikke fuldføre overførslen. Åbn Quick Share på Android-enheden, og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share konnte die Übertragung nicht abschließen. Öffne Quick Share auf dem Android-Gerät und versuche es erneut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Quick Share δεν μπόρεσε να ολοκληρώσει τη μεταφορά. Ανοίξτε το Quick Share στη συσκευή Android και δοκιμάστε ξανά."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share could not complete the transfer. Open Quick Share on the Android device and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share no pudo completar la transferencia. Abre Quick Share en el dispositivo Android e inténtalo de nuevo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share ei saanud edastust lõpule viia. Avage Android-seadmes Quick Share ja proovige uuesti."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share ei voinut viimeistellä siirtoa. Avaa Quick Share Android-laitteessa ja yritä uudelleen."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Hindi natapos ng Quick Share ang transfer. Buksan ang Quick Share sa Android device at subukang muli."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share n’a pas pu terminer le transfert. Ouvrez Quick Share sur l’appareil Android et réessayez."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share לא הצליח להשלים את ההעברה. פתח את Quick Share במכשיר Android ונסה שוב."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share ट्रांसफर पूरा नहीं कर सका। Android डिवाइस पर Quick Share खोलें और फिर कोशिश करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share nije mogao dovršiti prijenos. Otvorite Quick Share na Android uređaju i pokušajte ponovno."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Quick Share nem tudta befejezni az átvitelt. Nyisd meg a Quick Share-t az Android-eszközön, majd próbáld újra."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share tidak dapat menyelesaikan transfer. Buka Quick Share di perangkat Android dan coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share non ha potuto completare il trasferimento. Apri Quick Share sul dispositivo Android e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Shareで送信を完了できませんでした。Android端末側でQuick Shareを開き直して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share가 전송을 완료하지 못했습니다. Android 기기에서 Quick Share를 다시 열고 다시 시도하세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share negalėjo užbaigti perkėlimo. Atidarykite Quick Share Android įrenginyje ir bandykite dar kartą."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share nevarēja pabeigt pārsūtīšanu. Atveriet Quick Share Android ierīcē un mēģiniet vēlreiz."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share tidak dapat melengkapkan pemindahan. Buka Quick Share pada peranti Android dan cuba lagi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share kunne ikke fullføre overføringen. Åpne Quick Share på Android-enheten og prøv igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share kon de overdracht niet voltooien. Open Quick Share op het Android-apparaat en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share nie mógł zakończyć transferu. Otwórz Quick Share na urządzeniu Android i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Quick Share não conseguiu concluir a transferência. Abra o Quick Share no dispositivo Android e tente novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O Quick Share não conseguiu concluir a transferência. Abra o Quick Share no dispositivo Android e tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share nu a putut finaliza transferul. Deschide Quick Share pe dispozitivul Android și încearcă din nou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share не удалось завершить передачу. Откройте Quick Share на устройстве Android и повторите попытку."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share nemohol dokončiť prenos. Otvorte Quick Share na zariadení Android a skúste to znova."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share ni mogel dokončati prenosa. Odprite Quick Share v napravi Android in poskusite znova."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share није могао да заврши пренос. Отворите Quick Share на Android уређају и покушајте поново."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share kunde inte slutföra överföringen. Öppna Quick Share på Android-enheten och försök igen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share ไม่สามารถส่งให้เสร็จได้ เปิด Quick Share บนอุปกรณ์ Android แล้วลองอีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share aktarımı tamamlayamadı. Android aygıtta Quick Share'i açıp tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share не вдалося завершити передавання. Відкрийте Quick Share на пристрої Android і повторіть спробу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share không thể hoàn tất chuyển. Mở Quick Share trên thiết bị Android rồi thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share 无法完成传输。请在 Android 设备上重新打开 Quick Share，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Share 無法完成傳送。請在 Android 裝置上重新開啟 Quick Share，然後再試一次。"
          }
        }
      }
    },
