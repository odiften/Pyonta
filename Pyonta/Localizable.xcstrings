    "LaunchAtLogin.Tooltip": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يبدأ Pyonta تلقائيًا عند تسجيل الدخول إلى Mac."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Когато е включено, Pyonta се стартира автоматично, когато влезете в Mac."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "চালু থাকলে Mac-এ লগইন করার সময় Pyonta নিজে থেকে চালু হবে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Quan és activat, Pyonta s'obre automàticament quan inicies sessió al Mac."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Když je zapnuto, Pyonta se automaticky spustí po přihlášení k Macu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når dette er slået til, starter Pyonta automatisk, når du logger ind på din Mac."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, startet Pyonta automatisch, wenn du dich an deinem Mac anmeldest."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Όταν είναι ενεργό, το Pyonta ξεκινά αυτόματα όταν συνδέεστε στο Mac."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, Pyonta starts automatically when you log in to your Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, Pyonta se inicia automáticamente al iniciar sesión en tu Mac."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kui see on sees, käivitub Pyonta automaatselt, kui logite Maci sisse."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun tämä on käytössä, Pyonta käynnistyy automaattisesti, kun kirjaudut Maciin."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapag naka-on, awtomatikong magsisimula ang Pyonta kapag nag-login ka sa Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, Pyonta démarre automatiquement à l’ouverture de session sur votre Mac."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כאשר מופעל, Pyonta יופעל אוטומטית בעת התחברות ל-Mac."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चालू होने पर, Mac में लॉगिन करते समय Pyonta अपने आप शुरू होगा।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kada je uključeno, Pyonta se automatski pokreće kada se prijavite na Mac."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekapcsolva a Pyonta automatikusan elindul, amikor bejelentkezel a Mac-edre."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika aktif, Pyonta berjalan otomatis saat Anda login ke Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se attivato, Pyonta si avvia automaticamente quando accedi al tuo Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、Mac にログインしたときに Pyonta が自動で起動します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜져 있으면 Mac에 로그인할 때 Pyonta가 자동으로 실행됩니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Kai įjungta, Pyonta paleidžiama automatiškai, kai prisijungiate prie Mac."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kad ieslēgts, Pyonta automātiski startē, kad piesakāties Mac."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Apabila dihidupkan, Pyonta bermula secara automatik apabila anda log masuk ke Mac."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Når dette er på, starter Pyonta automatisk når du logger inn på Macen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Indien ingeschakeld, start Pyonta automatisch wanneer je inlogt op je Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdy włączone, Pyonta uruchamia się automatycznie po zalogowaniu do Maca."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o Pyonta inicia automaticamente ao você fazer login no Mac."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o Pyonta inicia automaticamente ao iniciar sessão no Mac."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Când este activat, Pyonta pornește automat la autentificarea în Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если включено, Pyonta запускается автоматически при входе в систему Mac."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Keď je zapnuté, Pyonta sa automaticky spustí po prihlásení do Macu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko je vklopljeno, se Pyonta samodejno zažene, ko se prijavite v Mac."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Када је укључено, Pyonta се аутоматски покреће када се пријавите на Mac."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "När detta är på startar Pyonta automatiskt när du loggar in på din Mac."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เมื่อเปิด Pyonta จะเริ่มทำงานโดยอัตโนมัติเมื่อคุณเข้าสู่ระบบ Mac"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açıkken Mac'inize giriş yaptığınızda Pyonta otomatik olarak başlar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коли увімкнено, Pyonta запускається автоматично під час входу в Mac."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khi bật, Pyonta tự động khởi động khi bạn đăng nhập vào Mac."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后,Pyonta 将在你登录 Mac 时自动启动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後,Pyonta 會在你登入 Mac 時自動啟動。"
          }
        }
      }
    },
