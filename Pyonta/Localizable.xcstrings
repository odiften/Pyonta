    "OpenReceivedURLs.Tooltip": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "متاح عند تفعيل الاستلام دون سؤال. عند تشغيله، تُفتح عناوين URL من Android فورًا في متصفحك الافتراضي؛ وعند إيقافه، تُنسخ إلى الحافظة."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Достъпно, когато Получаване без питане е включено. Когато е включено, URL адресите от Android се отварят веднага в браузъра по подразбиране; когато е изключено, се копират в клипборда."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "জিজ্ঞাসা ছাড়া গ্রহণ চালু থাকলে ব্যবহার করা যায়। চালু থাকলে Android থেকে URL সঙ্গে সঙ্গে আপনার ডিফল্ট ব্রাউজারে খুলবে; বন্ধ থাকলে ক্লিপবোর্ডে কপি হবে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponible quan Rep sense preguntar és activat. Si és activat, els URL d'Android s'obren immediatament al navegador predeterminat; si no, es copien al porta-retalls."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostupné, když je zapnuto Přijímat bez dotazu. Když je zapnuto, URL z Androidu se okamžitě otevřou ve výchozím prohlížeči; když je vypnuto, zkopírují se do schránky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgængelig, når Modtag uden at spørge er slået til. Når dette er slået til, åbnes URL'er fra Android straks i din standardbrowser; ellers kopieres de til udklipsholderen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfügbar, wenn Ohne Nachfrage empfangen aktiv ist. Ist dies eingeschaltet, öffnen sich URLs von Android sofort im Standardbrowser; andernfalls werden sie in die Zwischenablage kopiert."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαθέσιμο όταν η Λήψη χωρίς ερώτηση είναι ενεργή. Όταν είναι ενεργό, URL από Android ανοίγουν αμέσως στο προεπιλεγμένο πρόγραμμα περιήγησης· όταν είναι ανενεργό, αντιγράφονται στο πρόχειρο."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Available when Receive without asking is on. When on, URLs from Android open in your default browser immediately; when off, URLs are copied to clipboard."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponible cuando Recibir sin preguntar está activado. Si está activado, las URLs de Android se abren de inmediato en tu navegador predeterminado; si está desactivado, se copian al portapapeles."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Saadaval, kui Võta vastu küsimata on sees. Kui see on sees, avatakse Androidist tulevad URL-id kohe vaikebrauseris; kui väljas, kopeeritakse need lõikelauale."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytettävissä, kun Vastaanota kysymättä on käytössä. Kun tämä on käytössä, Androidista tulevat URL-osoitteet avautuvat heti oletusselaimessa; muuten ne kopioidaan leikepöydälle."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Available kapag naka-on ang Tumanggap nang walang tanong. Kapag naka-on, agad na bubukas ang mga URL mula Android sa default browser; kapag naka-off, kokopyahin ang mga ito sa clipboard."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponible lorsque Recevoir sans demander est activé. Si activé, les URL d’Android s’ouvrent immédiatement dans le navigateur par défaut; sinon, elles sont copiées dans le presse-papiers."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "זמין כאשר קבל בלי לשאול מופעל. כאשר מופעל, כתובות URL מ-Android נפתחות מיד בדפדפן ברירת המחדל; כאשר כבוי, הן מועתקות ללוח."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिना पूछे प्राप्त करें चालू होने पर उपलब्ध। चालू होने पर Android से आए URL तुरंत आपके डिफ़ॉल्ट ब्राउज़र में खुलते हैं; बंद होने पर वे क्लिपबोर्ड में कॉपी होते हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostupno kada je uključeno Primaj bez pitanja. Kada je uključeno, URL-ovi s Androida odmah se otvaraju u zadanom pregledniku; kada je isključeno, kopiraju se u međuspremnik."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Akkor érhető el, ha a Fogadás kérdés nélkül be van kapcsolva. Bekapcsolva az Androidról érkező URL-ek azonnal megnyílnak az alapértelmezett böngészőben; kikapcsolva a vágólapra másolódnak."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tersedia saat Terima tanpa bertanya aktif. Jika aktif, URL dari Android langsung terbuka di browser default; jika nonaktif, URL disalin ke papan klip."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponibile quando Ricevi senza chiedere è attivo. Se attivo, gli URL da Android si aprono subito nel browser predefinito; se disattivo, vengono copiati negli appunti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「確認なしで受信」がオンのときに使えます。オンの場合、Android からのURLをすぐ既定のブラウザで開きます。オフの場合はクリップボードへコピーします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인 없이 받기가 켜져 있을 때 사용할 수 있습니다. 켜면 Android에서 온 URL을 즉시 기본 브라우저로 열고, 끄면 클립보드에 복사합니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasiekiama, kai įjungta Gauti neklausiant. Kai įjungta, URL iš Android iš karto atidaromi numatytojoje naršyklėje; kai išjungta, nukopijuojami į iškarpinę."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pieejams, kad ieslēgts Saņemt bez jautāšanas. Kad ieslēgts, URL no Android uzreiz atveras noklusējuma pārlūkā; kad izslēgts, tie tiek kopēti starpliktuvē."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tersedia apabila Terima tanpa bertanya dihidupkan. Apabila dihidupkan, URL daripada Android dibuka serta-merta dalam penyemak imbas lalai; apabila dimatikan, URL disalin ke papan klip."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgjengelig når Motta uten å spørre er på. Når dette er på, åpnes URL-er fra Android umiddelbart i standardnettleseren; når av, kopieres de til utklippstavlen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beschikbaar wanneer Ontvangen zonder vragen aan staat. Ingeschakeld openen URL's van Android direct in je standaardbrowser; uitgeschakeld worden ze naar het klembord gekopieerd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostępne, gdy Odbieraj bez pytania jest włączone. Gdy włączone, URL z Androida otwierają się natychmiast w domyślnej przeglądarce; gdy wyłączone, są kopiowane do schowka."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponível quando Receber sem perguntar está ativado. Ativado, URLs do Android abrem imediatamente no navegador padrão; desativado, são copiadas para a área de transferência."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponível quando Receber sem perguntar está ativado. Ativado, os URLs do Android abrem imediatamente no navegador predefinido; desativado, são copiados para a área de transferência."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponibil când Primește fără confirmare este activat. Când este activat, URL-urile de pe Android se deschid imediat în browserul implicit; când este dezactivat, sunt copiate în clipboard."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступно, когда включено Получать без подтверждения. Если включено, URL с Android сразу открываются в браузере по умолчанию; если выключено, копируются в буфер обмена."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostupné, keď je zapnuté Prijímať bez opýtania. Keď je zapnuté, URL z Androidu sa okamžite otvoria v predvolenom prehliadači; keď je vypnuté, skopírujú sa do schránky."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na voljo, ko je vklopljeno Prejmi brez vprašanja. Ko je vklopljeno, se URL-ji iz Androida takoj odprejo v privzetem brskalniku; ko je izklopljeno, se kopirajo v odložišče."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступно када је укључено Примај без питања. Када је укључено, URL-ови са Android-а се одмах отварају у подразумеваном прегледачу; када је искључено, копирају се у клипборд."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillgängligt när Ta emot utan att fråga är på. När detta är på öppnas URL:er från Android direkt i standardwebbläsaren; när det är av kopieras de till urklipp."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ได้เมื่อเปิดรับโดยไม่ถาม เมื่อเปิด URL จาก Android จะเปิดทันทีในเบราว์เซอร์เริ่มต้น เมื่อปิด URL จะถูกคัดลอกไปยังคลิปบอร์ด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sormadan al açıkken kullanılabilir. Açıkken Android'den gelen URL'ler varsayılan tarayıcınızda hemen açılır; kapalıyken panoya kopyalanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступно, коли ввімкнено Отримувати без підтвердження. Якщо ввімкнено, URL з Android одразу відкриваються у браузері за замовчуванням; якщо вимкнено, копіюються до буфера обміну."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khả dụng khi Nhận mà không hỏi được bật. Khi bật, URL từ Android mở ngay trong trình duyệt mặc định; khi tắt, URL được sao chép vào clipboard."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在开启无需确认接收时可用。开启后，来自 Android 的 URL 会立即用默认浏览器打开；关闭时会复制到剪贴板。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在開啟無需確認接收時可用。開啟後，來自 Android 的 URL 會立即用預設瀏覽器開啟；關閉時會複製到剪貼簿。"
          }
        }
      }
    },
