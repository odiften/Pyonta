    "PlusNoOfferings.Message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تتوفر منتجات Pyonta+ بعد. تحقق من إعدادات RevenueCat offering ومنتجات App Store Connect."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Все още няма налични продукти Pyonta+. Проверете offering в RevenueCat и настройките на продуктите в App Store Connect."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এখনও কোনো Pyonta+ পণ্য পাওয়া যাচ্ছে না। RevenueCat offering এবং App Store Connect পণ্য সেটআপ দেখুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Encara no hi ha productes Pyonta+ disponibles. Comprova l'offering de RevenueCat i la configuració de productes a App Store Connect."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zatím nejsou k dispozici žádné produkty Pyonta+. Zkontrolujte offering v RevenueCat a nastavení produktů v App Store Connect."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der er endnu ingen Pyonta+-produkter tilgængelige. Kontroller RevenueCat-offering og produktopsætningen i App Store Connect."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es sind noch keine Pyonta+-Produkte verfügbar. Prüfe das RevenueCat-Offering und die Produkteinstellungen in App Store Connect."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχουν ακόμη διαθέσιμα προϊόντα Pyonta+. Ελέγξτε το offering του RevenueCat και τη ρύθμιση προϊόντων στο App Store Connect."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Pyonta+ products are available yet. Check the RevenueCat offering and App Store Connect product setup."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay productos de Pyonta+ disponibles. Revisa el offering de RevenueCat y la configuración de productos en App Store Connect."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ tooteid pole veel saadaval. Kontrollige RevenueCati offeringut ja App Store Connecti toote seadistust."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+-tuotteita ei ole vielä saatavilla. Tarkista RevenueCat offering ja App Store Connectin tuoteasetukset."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Wala pang available na Pyonta+ products. Suriin ang RevenueCat offering at App Store Connect product setup."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun produit Pyonta+ n’est encore disponible. Vérifiez l’offering RevenueCat et la configuration des produits dans App Store Connect."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "עדיין אין מוצרי Pyonta+ זמינים. בדוק את ה-offering ב-RevenueCat ואת הגדרת המוצרים ב-App Store Connect."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कोई Pyonta+ उत्पाद उपलब्ध नहीं है। RevenueCat offering और App Store Connect product setup जांचें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Još nema dostupnih Pyonta+ proizvoda. Provjerite RevenueCat offering i postavke proizvoda u App Store Connectu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Még nem érhetők el Pyonta+ termékek. Ellenőrizd a RevenueCat offeringet és az App Store Connect termékbeállításait."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada produk Pyonta+ yang tersedia. Periksa offering RevenueCat dan pengaturan produk App Store Connect."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non sono ancora disponibili prodotti Pyonta+. Controlla l’offering RevenueCat e la configurazione dei prodotti in App Store Connect."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ の商品がまだ取得できません。RevenueCat の offering と App Store Connect の商品設定を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ 상품을 아직 사용할 수 없습니다. RevenueCat offering과 App Store Connect 상품 설정을 확인하세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Dar nėra pasiekiamų Pyonta+ produktų. Patikrinkite RevenueCat offering ir App Store Connect produktų nustatymus."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyonta+ produkti vēl nav pieejami. Pārbaudiet RevenueCat offering un App Store Connect produktu iestatījumus."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada produk Pyonta+ tersedia lagi. Semak offering RevenueCat dan persediaan produk App Store Connect."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen Pyonta+-produkter er tilgjengelige ennå. Kontroller RevenueCat-offering og produktoppsettet i App Store Connect."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er zijn nog geen Pyonta+-producten beschikbaar. Controleer de RevenueCat-offering en de productinstellingen in App Store Connect."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie ma jeszcze dostępnych produktów Pyonta+. Sprawdź offering w RevenueCat i konfigurację produktów w App Store Connect."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há produtos Pyonta+ disponíveis. Verifique a offering da RevenueCat e a configuração de produtos no App Store Connect."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há produtos Pyonta+ disponíveis. Verifique a offering da RevenueCat e a configuração de produtos no App Store Connect."
          }
        },
        "ro": {
          "stringUnit": {
